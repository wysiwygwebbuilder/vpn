{
  "expo": {
    "name": "Феникс VPN",
    "slug": "van21",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "light",
    "scheme": "phoenix-vpn",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f97316"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phoenix.vpn"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#160a11"
      },
      "predictiveBackGestureEnabled": true,
      "package": "com.phoenix.vpn"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3b6c3476-5d81-4e75-8203-efd3a404cbab"
      }
    },
    "owner": "web-impuls3"
  }
}
